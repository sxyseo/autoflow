{
  "$schema": "./qa_gates.schema.json",
  "version": "1.0.0",
  "severity_levels": {
    "critical": {
      "description": "Must fix before commit",
      "blocks_commit": true,
      "color": "red"
    },
    "high": {
      "description": "Should fix before commit",
      "blocks_commit": true,
      "color": "orange"
    },
    "medium": {
      "description": "Warning - doesn't block commit",
      "blocks_commit": false,
      "color": "yellow"
    },
    "low": {
      "description": "Info only - doesn't block commit",
      "blocks_commit": false,
      "color": "blue"
    }
  },
  "coverage": {
    "enabled": true,
    "thresholds": {
      "minimum": 80.0,
      "branches": 75.0,
      "functions": 80.0,
      "lines": 80.0
    },
    "module_overrides": {},
    "fail_on_error": true
  },
  "duplication": {
    "enabled": true,
    "thresholds": {
      "similarity": 0.85,
      "minimum_lines": 10,
      "minimum_tokens": 50,
      "chunk_size": 50
    },
    "detection_methods": ["ast", "token_based", "fingerprint"],
    "exclude_patterns": [
      "*/test*.py",
      "*/__pycache__/*",
      "*/node_modules/*",
      "*/migrations/*",
      "*.min.js",
      "*.min.css"
    ],
    "severity_mapping": {
      "high": {
        "similarity": 0.95,
        "lines": 50
      },
      "medium": {
        "similarity": 0.85,
        "lines": 30
      },
      "low": {
        "similarity": 0.75,
        "lines": 10
      }
    },
    "output_path": ".autoflow/duplication_findings.json",
    "fail_on_error": false,
    "generate_report": true
  },
  "approval": {
    "require_tests": true,
    "require_coverage": true,
    "require_qa_check": true,
    "blocking_severities": ["CRITICAL", "HIGH"],
    "token_expiry_hours": 24,
    "token_path": ".autoflow/approval_token.json"
  },
  "test_suites": {
    "unit": {
      "description": "Unit tests",
      "patterns": ["test_*.py"],
      "required": true
    },
    "integration": {
      "description": "Integration tests",
      "patterns": ["test_integration*.py"],
      "required": true
    },
    "e2e": {
      "description": "End-to-end tests",
      "patterns": ["test_e2e*.py"],
      "required": false
    },
    "all": {
      "description": "All tests",
      "patterns": ["test*.py"],
      "required": true
    }
  },
  "qa_findings": {
    "enabled": true,
    "categories": [
      "test_failure",
      "coverage_gap",
      "code_quality",
      "duplication",
      "security",
      "performance",
      "style"
    ],
    "max_findings": 100,
    "output_path": ".autoflow/qa_findings.json"
  },
  "verification": {
    "run_tests": true,
    "run_coverage": true,
    "check_thresholds": true,
    "generate_findings": true,
    "grant_approval": true,
    "generate_fix_tasks": true,
    "fix_task_agent": "implementation-runner",
    "fix_tasks_output_dir": ".autoflow/tasks"
  }
}
